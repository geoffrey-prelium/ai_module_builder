<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Project Form View -->
    <record id="view_ai_module_project_form" model="ir.ui.view">
        <field name="name">ai.module.project.form</field>
        <field name="model">ai.module.project</field>
        <field name="arch" type="xml">
            <form string="AI Module Project">
                <header>
                    <button name="action_start_discussion" string="Start Discussion" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_generate_code" string="Force Generation" type="object" invisible="state in ['draft', 'generating', 'done']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,conversing,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="E.g., 3D Printer Fleet Management"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="technical_name"/>
                            <field name="llm_provider"/>
                        </group>
                        <group>
                            <field name="zip_attachment_id" readonly="1" invisible="not zip_attachment_id" widget="many2one_binary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Initial Need" name="description_page">
                            <field name="description" placeholder="Describe the application you want to build..."/>
                        </page>
                        <page string="Architect Chat" name="chat_page" invisible="state == 'draft'">
                            <group>
                                <!-- History -->
                                <field name="message_ids" readonly="1" nolabel="1" colspan="2">
                                    <list string="Conversation">
                                        <field name="create_date"/>
                                        <field name="role" widget="badge"/>
                                        <field name="content"/>
                                    </list>
                                </field>
                            </group>
                            
                            <hr/>
                            <group invisible="state in ['generating', 'done']">
                                <field name="new_message" placeholder="Type your answer to the Architect here..."/>
                                <button name="action_send_message" string="Send Message" type="object" class="btn-primary" icon="fa-paper-plane"/>
                            </group>
                            <label for="new_message" string="The AI will respond shortly after you send." class="text-muted" invisible="state in ['generating', 'done']"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Project Kanban View -->
    <record id="view_ai_module_project_kanban" model="ir.ui.view">
        <field name="name">ai.module.project.kanban</field>
        <field name="model">ai.module.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="state"/>
                <field name="llm_provider"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="llm_provider" widget="badge"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_ai_module_project" model="ir.actions.act_window">
        <field name="name">AI Module Projects</field>
        <field name="res_model">ai.module.project</field>
        <field name="view_mode">kanban,form</field>
    </record>

    <menuitem id="ai_module_project_menu"
              name="Projects"
              parent="ai_module_builder_menu_root"
              action="action_ai_module_project"
              sequence="10"/>
</odoo>
